OnMastodonTootRequest
{
	_rand = RAND(10)

	if _rand == 0 {
		_time = (hour() + 9) % 24
		case _time {
			when 9 {
				ランダムトーク朝
			}
			when 15 {
				ランダムトーク昼
			}
			when 21 {
				ランダムトーク夜
			}
			others {
				ランダムトーク通常
			}
		}
	}
	else {
		ランダムトーク通常
	}
}

OnMastodonMentionRequest
{
	メンション返信占い
}

OnMastodonMentionNoFortuneRequest
{
	メンション返信通常
}