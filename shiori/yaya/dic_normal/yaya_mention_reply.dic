// --------------------------------
// メンション返信
// --------------------------------

メンション返信通常 : nonoverlap
{
	'ミャーごろ。'
	'ふミャー。'
	'ミャーん。'
	'ミャッ！？'
	'ミャ！？'
	'んミャ！？'
	--
	'\n……ぷーに占って欲しいときは、「占って」って言うミャ。'
}

メンション返信占い
{
	_card = Fortune_CardsList[RAND(33)]

	_talk = 占い前コメント + '\n'
	_talk += "出たカードは、「%(_card[0])の%(_card[1])」ミャ。\n\n"
	_talk += EVAL('占い解説'+_card[0]) + '\n\n'
	_talk += EVAL('占い解説'+_card[1]) + '\n\n'
	_talk += 占いの擬音 + '\n'
	_talk += 占い後コメント

	_talk
}