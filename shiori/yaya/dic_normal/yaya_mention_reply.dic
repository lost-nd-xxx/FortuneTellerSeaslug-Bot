// --------------------------------
// メンション返信（占いなし）
// --------------------------------

メンション返信通常 : nonoverlap
{
	'ミャーごろ。'
	'ふミャー。'
	'ミャーん。'
	'ミャッ！？'
	'ミャ！？'
	'んミャ！？'
	--
	'\n……ぷーに占って欲しいときは、「占って」って言うミャ。'
}

メンション返信占い
{
	_card = Fortune_CardsList[RAND(33)]
	_card[0] = EVAL('占い解説'+_card[0])
	_card[1] = EVAL('占い解説'+_card[1])

	_talk = 占い前コメント + '\n\n'
	_talk += _card[0] + '\n\n'
	_talk += _card[1] + '\n\n'
	_talk += 占いの擬音 + '\n'
	_talk += 占い後コメント

	_talk
}